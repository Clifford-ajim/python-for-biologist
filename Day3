#3.5 Loop Control: break and continue
# continue — skip ambiguous nucleotides
sequence = "ATCNGNNTCG" # N = unknown nucleotide
valid_count = 0
for base in sequence:
    if base == "N":
        continue # Skip this base, go to next iteration
    valid_count += 1
    print(f"Processing base: {base}")
print(f"Valid bases processed: {valid_count}")
# break — stop searching once target found
# Find the position of the first stop codon (TAG, TAA, or TGA)
codons = ["ATG", "GGC", "TAG", "ATT", "CGA"] # Mock ORF
print("Scanning reading frame...")
for i, codon in enumerate(codons): # enumerate() gives both index and value
    print(f" Position {i}: {codon}")
    if codon in ["TAG", "TAA", "TGA"]:
        print(f" Stop codon found at position {i}!")
        break # No need to read further
#3.6 Nested Loops: Cells Within Organisms
# Compare all pairs of sequences for similarity
sequences = ["ATCG", "ATGG", "GCTA"]
names = ["seq1", "seq2", "seq3"]
print("Pairwise sequence comparison:")
for i in range(len(sequences)):
    for j in range(i + 1, len(sequences)): # Start at i+1 to avoid repeats
        seq_a = sequences[i]
        seq_b = sequences[j]
        # Count matching positions
        matches = 0
        for pos in range(len(seq_a)):
            if seq_a[pos] == seq_b[pos]:
                matches += 1
        similarity = (matches / len(seq_a)) * 100
        print(f" {names[i]} vs {names[j]}: {similarity:.0f}% identity")

#3.7 A Complete Loop-Powered Sequence Analyzer
# sequence_stats.py
# Full analysis of a DNA sequence using loops
sequence = "ATCGGCTATGCCAAGCTAGCGGTAATCGATCGATCG"
# Initialize counters
nucleotide_counts = {"A": 0, "T": 0, "G": 0, "C": 0, "N": 0}
for base in sequence.upper(): # .upper() handles lowercase input
    if base in nucleotide_counts:
        nucleotide_counts[base] += 1
    else:
        nucleotide_counts["N"] += 1 # Unknown base
total_valid = len(sequence) - nucleotide_counts["N"]
print("=== Nucleotide Composition ===")
for base, count in nucleotide_counts.items():
    if base != "N":
        percentage = (count / total_valid) * 100
        bar = "#" * int(percentage / 2) # ASCII bar chart!
        print(f" {base}: {count:3d} ({percentage:5.1f}%) |{bar}")
gc = nucleotide_counts["G"] + nucleotide_counts["C"]
print(f"GC content: {(gc/total_valid)*100:.1f}%")
print(f"AT/GC ratio: {(nucleotide_counts['A']+nucleotide_counts['T'])/gc:.2f}")
