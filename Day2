# Common Mistake: = vs ==
#Single equals (=) ASSIGNS a value to a variable: ph = 7.4
#Double equals (==) COMPARES two values: ph == 7.4
#Writing 'if ph = 7.4:' will give you a SyntaxError.
#Always use == when asking a question inside an if statement.
# 2.5 Logical Operators: AND, OR, NOT
# AND — both conditions must be True
temperature = 37
oxygen_level = 18.5 # % oxygen
if temperature >= 35 and oxygen_level >= 16:
    print("Conditions suitable for aerobic respiration")
else:
    print("Conditions unfavorable")
# OR — at least one condition must be True
species = "Acidobacteria"
if species == "Acidobacteria" or species == "Acidithiobacillus":
    print("Acidophilic organism detected")
# NOT — reverses True/False
sample_contaminated = False
if not sample_contaminated:
    print("Sample is clean — proceeding with analysis")
else:
    print("Sample contaminated — discard and re-collect")
