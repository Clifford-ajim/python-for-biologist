# Check dissolved oxygen (most critical for aquatic life)
if dissolved_oxygen >= 8.0:
    oxygen_status = "Excellent"
elif dissolved_oxygen >= 6.0:
    oxygen_status = "Good"
elif dissolved_oxygen >= 4.0:
    oxygen_status = "Moderate — fish stress likely"
else:
    oxygen_status = "Poor — aquatic life at risk"
# Check pH
if 6.5 <= ph <= 8.5:
    ph_status = "Normal"
else:
    ph_status = "Abnormal — check for pollution"
# Overall assessment
if dissolved_oxygen >= 6.0 and 6.5 <= ph <= 8.5 and nitrate_level <= 10:
    overall = "HEALTHY"
elif dissolved_oxygen >= 4.0 and 5.5 <= ph <= 9.0:
    overall = "MODERATE CONCERN"
else:
    overall = "POOR — INTERVENTION REQUIRED"

print(f"Oxygen status: {oxygen_status}")
print(f"pH status: {ph_status}")
