# 2.3 elif: Multiple Response Pathways
# Classifying a DNA sequence by GC content
gc_content = 0.68 # 68% GC
if gc_content < 0.40:
    classification = "AT-rich (low GC)"
    stability = "relatively unstable"
elif gc_content < 0.50:
    classification = "Moderate GC"
    stability = "moderate stability"
elif gc_content < 0.65:
    classification = "GC-rich"
    stability = "thermally stable"
else:
    classification = "Extremely GC-rich"
    stability = "very high thermal stability"
print(f"Classification: {classification}")
print(f"Thermal stability: {stability}")
# Output: Classification: Extremely GC-rich
# Thermal stability: very high thermal stability
# 2.4 Comparison Operators
a = 10
b = 20
print(a == b) # False — equal to?
print(a != b) # True — not equal to?
print(a < b) # True — less than?
print(a > b) # False — greater than?
print(a <= b) # True — less than or equal to?
print(a >= b) # False — greater than or equal to?
# Biological examples
population = 500
print(population > 1000) # False — above minimum viable population?
